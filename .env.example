# TTRPG Assistant - Environment Variables Template
# Copy this file to .env in the project root and fill in the values for your environment

# ==================== DATABASE (PostgreSQL) ====================
# Note: These variables are used by docker-compose.yml
POSTGRES_DB=ttrpg
POSTGRES_USER=ttrpg
POSTGRES_PASSWORD=ttrpg_pass

# For backend Spring application (when running directly, not in Docker)
DB_URL=jdbc:postgresql://localhost:5432/ttrpg_assistant
DB_USER=postgres
DB_PASS=your_postgres_password

# ==================== BACKEND SERVER ====================
SERVER_PORT=8080

# ==================== SECURITY & JWT ====================
# Generate a strong JWT secret: openssl rand -hex 32
# Minimum 32 characters required for HS256 algorithm
JWT_SECRET=change_me_to_random_long_string_minimum_32_characters
JWT_EXP_MIN=10080

# ==================== CORS ====================
# Comma-separated list of allowed origins for frontend
# Development: http://localhost:5173,http://localhost:3000
# Production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ==================== AI INTEGRATIONS ====================
# OpenAI API key for GPT models
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model: gpt-4, gpt-3.5-turbo, etc.
OPENAI_MODEL=gpt-4-turbo

# DeepAI API key for image generation
# Get key from: https://deepai.org/
DEEPAI_API_KEY=

# ==================== FRONTEND ====================
# API URL for frontend to connect to backend
VITE_API_URL=http://localhost:8080
